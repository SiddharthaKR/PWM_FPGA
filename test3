#!/usr/bin/env python3
# cpu_to_gpu_receiver.py
#
# Simulates traditional packet transfer:
#   NIC → CPU RAM → GPU (via cudaMemcpy)
#
# This is Case 1 baseline
# rxpci will measure throughput
# of this CPU copy path

import socket
import numpy as np
import threading
import time
import signal
import sys

try:
    import cupy as cp
    print("CuPy available ✅")
except ImportError:
    print("CuPy not available ❌")
    print("source ~/gpu_benchmark_env/bin/activate")
    sys.exit(1)

# ─── Config ──────────────────────────────
UDP_IP       = "0.0.0.0"
UDP_PORT     = 5201          # receive here
PKT_SIZE     = 1024          # expected pkt size
GPU_BUF_PKTS = 2048          # GPU buffer size
RUNNING      = True

# ─── GPU Buffer ──────────────────────────
# Allocate GPU buffer once
# same size as DOCA GPU buffer
gpu_buffer = cp.zeros(
    PKT_SIZE * GPU_BUF_PKTS,
    dtype=cp.uint8
)
gpu_write_idx = 0

# ─── Stats ───────────────────────────────
stats = {
    'packets': 0,
    'bytes':   0,
    'dropped': 0
}

def signal_handler(sig, frame):
    global RUNNING
    RUNNING = False
    print("\nStopping...")

signal.signal(signal.SIGINT, signal_handler)


def receive_and_copy():
    """
    Main loop:
    1. Receive UDP packet from NIC
       into CPU RAM
    2. Copy CPU RAM → GPU RAM
       via cudaMemcpy (cp.asarray)
    3. Increment write index
    """
    global gpu_write_idx, RUNNING

    # Create UDP socket
    sock = socket.socket(
        socket.AF_INET,
        socket.SOCK_DGRAM
    )
    sock.setsockopt(
        socket.SOL_SOCKET,
        socket.SO_RCVBUF,
        1024 * 1024 * 256  # 256MB socket buf
    )
    sock.bind((UDP_IP, UDP_PORT))
    sock.settimeout(1.0)

    print(f"Listening on UDP port {UDP_PORT}")
    print("Receiving packets and copying to GPU...")
    print("")

    # Pre-allocate CPU receive buffer
    # reuse same buffer each packet
    # = minimize allocation overhead
    cpu_buf = np.zeros(
        PKT_SIZE,
        dtype=np.uint8
    )

    while RUNNING:
        try:
            # Step 1: Receive packet into CPU RAM
            # this is what NIC driver does
            # in traditional architecture
            data, addr = sock.recvfrom(PKT_SIZE)

            # Step 2: Put in numpy array
            # = CPU RAM buffer
            pkt_len = min(len(data), PKT_SIZE)
            cpu_buf[:pkt_len] = np.frombuffer(
                data[:pkt_len],
                dtype=np.uint8
            )

            # Step 3: Copy CPU RAM → GPU RAM
            # THIS is what rxpci measures
            # = traditional cudaMemcpy path
            offset = gpu_write_idx * PKT_SIZE
            gpu_buffer[offset:offset+pkt_len] = \
                cp.asarray(
                    cpu_buf[:pkt_len]
                )

            # Increment circular buffer index
            gpu_write_idx = (
                (gpu_write_idx + 1) %
                GPU_BUF_PKTS
            )

            # Update stats
            stats['packets'] += 1
            stats['bytes']   += pkt_len

        except socket.timeout:
            continue
        except Exception as e:
            stats['dropped'] += 1
            continue

    sock.close()


def print_stats():
    """Print stats every 5 seconds"""
    prev_pkts  = 0
    prev_bytes = 0

    while RUNNING:
        time.sleep(5)

        pkts  = stats['packets']
        bytes = stats['bytes']

        dpkts  = pkts  - prev_pkts
        dbytes = bytes - prev_bytes

        pps  = dpkts  / 5
        gbps = (dbytes * 8) / 5 / 1e9

        print(f"[CPU→GPU] "
              f"pkts={dpkts} "
              f"pps={pps:.0f} "
              f"throughput={gbps:.3f}Gbps "
              f"total={pkts}")

        prev_pkts  = pkts
        prev_bytes = bytes


# ─── Main ────────────────────────────────

if __name__ == "__main__":

    print("=" * 50)
    print("  Case 1: Traditional CPU Path")
    print("  NIC → CPU RAM → GPU (cudaMemcpy)")
    print("  Measure with: nvidia-smi dmon -s t")
    print("=" * 50)
    print("")

    # Start stats thread
    stats_thread = threading.Thread(
        target=print_stats,
        daemon=True
    )
    stats_thread.start()

    # Run receiver in main thread
    receive_and_copy()

    print(f"\nFinal: {stats['packets']} packets"
          f" {stats['dropped']} dropped")
