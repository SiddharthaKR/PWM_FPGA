#!/bin/bash
# path_comparison.sh
# Compares CPU copy vs GPUDirect throughput

IFACE="enp70s0"
PKT_SIZE=1024
DURATION=10
OUTPUT="./results/path_comparison_$(date +%H%M%S).txt"

mkdir -p ./results

print_header() {
    echo "============================================" | tee -a $OUTPUT
    echo "  CPU Copy vs GPUDirect Throughput Test" | tee -a $OUTPUT
    echo "  $(date)" | tee -a $OUTPUT
    echo "============================================" | tee -a $OUTPUT
}

measure_rx_throughput() {
    local label=$1
    local duration=$2

    echo "" | tee -a $OUTPUT
    echo "Measuring: $label (${duration}s)" | tee -a $OUTPUT
    echo "────────────────────────────────────────" \
        | tee -a $OUTPUT

    local PREV=$(cat /sys/class/net/$IFACE/statistics/rx_bytes)
    local PREV_PKTS=$(cat \
        /sys/class/net/$IFACE/statistics/rx_packets)

    local total_gbps=0
    local samples=0
    local max_gbps=0

    for i in $(seq 1 $duration); do
        sleep 1
        local CURR=$(cat \
            /sys/class/net/$IFACE/statistics/rx_bytes)
        local CURR_PKTS=$(cat \
            /sys/class/net/$IFACE/statistics/rx_packets)

        local BDELTA=$(( CURR - PREV ))
        local PDELTA=$(( CURR_PKTS - PREV_PKTS ))
        local GBPS=$(echo "scale=3; \
            $BDELTA * 8 / 1000000000" | bc)
        local PPS=$(echo "scale=0; \
            $PDELTA / 1" | bc)

        echo "  ${i}s: ${GBPS} Gbps  ${PPS} pps" \
            | tee -a $OUTPUT

        total_gbps=$(echo "$total_gbps + $GBPS" | bc)
        samples=$(( samples + 1 ))

        IS_MAX=$(echo "$GBPS > $max_gbps" | bc)
        [ "$IS_MAX" = "1" ] && max_gbps=$GBPS

        PREV=$CURR
        PREV_PKTS=$CURR_PKTS
    done

    local avg=$(echo "scale=3; \
        $total_gbps / $samples" | bc)

    echo "" | tee -a $OUTPUT
    echo "  Average : ${avg} Gbps" | tee -a $OUTPUT
    echo "  Peak    : ${max_gbps} Gbps" | tee -a $OUTPUT
    echo $avg
}

# ─── Main ────────────────────────────────────────
print_header

# ── Phase 1: CPU path ────────────────────────────
echo "" | tee -a $OUTPUT
echo "PHASE 2 — Traditional CPU Path" | tee -a $OUTPUT
echo "  Make sure DOCA app is NOT running" | tee -a $OUTPUT
echo "  Start iperf3 on Server B now:" | tee -a $OUTPUT
echo "  iperf3 -u -c 192.168.1.1 -b 100G -P 10 -t 30" \
    | tee -a $OUTPUT
echo "" | tee -a $OUTPUT
read -p "Press ENTER when iperf3 is running..."

CPU_GBPS=$(measure_rx_throughput "CPU Path" $DURATION)

# CPU metrics
CPU_SOFT=$(mpstat 1 3 | \
    awk '/Average.*all/{print $10}')
CPU_IRQ=$(cat /proc/interrupts | \
    grep mlx | \
    awk '{sum+=$2} END {print sum}')

echo "" | tee -a $OUTPUT
echo "  CPU Softirq    : ${CPU_SOFT}%" | tee -a $OUTPUT
echo "  Total IRQ count: ${CPU_IRQ}" | tee -a $OUTPUT

# ── Phase 2: GPUDirect path ──────────────────────
echo "" | tee -a $OUTPUT
echo "PHASE 3 — GPUDirect RDMA Path" | tee -a $OUTPUT
echo "  Start DOCA app on Server A now" | tee -a $OUTPUT
echo "  Start iperf3 on Server B now:" | tee -a $OUTPUT
echo "  iperf3 -u -c 192.168.1.1 -b 100G -P 10 -t 30" \
    | tee -a $OUTPUT
echo "" | tee -a $OUTPUT
read -p "Press ENTER when both are running..."

GPU_GBPS=$(measure_rx_throughput "GPUDirect Path" $DURATION)

# GPU metrics
GPU_UTIL=$(nvidia-smi \
    --query-gpu=utilization.gpu \
    --format=csv,noheader,nounits | tr -d ' ')
GPU_MEM=$(nvidia-smi \
    --query-gpu=memory.used \
    --format=csv,noheader,nounits | tr -d ' ')
GPU_SOFT=$(mpstat 1 3 | \
    awk '/Average.*all/{print $10}')
GPU_IRQ=$(cat /proc/interrupts | \
    grep mlx | \
    awk '{sum+=$2} END {print sum}')

echo "" | tee -a $OUTPUT
echo "  GPU Utilization: ${GPU_UTIL}%" | tee -a $OUTPUT
echo "  GPU Memory Used: ${GPU_MEM} MiB" | tee -a $OUTPUT
echo "  CPU Softirq    : ${GPU_SOFT}%" | tee -a $OUTPUT
echo "  Total IRQ count: ${GPU_IRQ}" | tee -a $OUTPUT

# ── Final Comparison ─────────────────────────────
echo "" | tee -a $OUTPUT
echo "============================================" \
    | tee -a $OUTPUT
echo "  FINAL COMPARISON" | tee -a $OUTPUT
echo "============================================" \
    | tee -a $OUTPUT

awk -v cpu=$CPU_GBPS \
    -v gpu=$GPU_GBPS \
    -v cs=$CPU_SOFT \
    -v gs=$GPU_SOFT \
    -v ci=$CPU_IRQ \
    -v gi=$GPU_IRQ \
    -v gutil=$GPU_UTIL \
'BEGIN {
    tput_diff = gpu - cpu
    soft_saved = cs - gs
    irq_diff = ci - gi

    printf "\n"
    printf "  %-25s %-15s %-15s\n",
        "Metric", "CPU Path", "GPUDirect"
    printf "  %s\n", \
        "─────────────────────────────────────────────"
    printf "  %-25s %-15s %-15s\n",
        "RX Throughput",
        cpu " Gbps",
        gpu " Gbps"
    printf "  %-25s %-15s %-15s\n",
        "CPU Softirq",
        cs "%",
        gs "%"
    printf "  %-25s %-15s %-15s\n",
        "GPU Utilization",
        "0%",
        gutil "%"
    printf "  %-25s %-15s %-15s\n",
        "IRQ Count",
        ci,
        gi
    printf "  %s\n", \
        "─────────────────────────────────────────────"
    printf "\n"
    printf "  Softirq CPU saved : %.1f%%\n", soft_saved
    printf "  Throughput delta  : %.3f Gbps\n", tput_diff
    printf "\n"

    if (soft_saved > 10)
        print "  Verdict: DPU offload confirmed ✅"
    else
        print "  Verdict: Minimal offload detected"
    printf "\n"
}' | tee -a $OUTPUT

echo "============================================" \
    | tee -a $OUTPUT
echo "Saved to: $OUTPUT"
