#!/bin/bash
# monitor_resources.sh
# Captures CPU and GPU metrics during test

LABEL=${1:-"test"}
DURATION=40
OUTPUT_DIR="./results"
TS=$(date +"%H%M%S")

mkdir -p $OUTPUT_DIR

echo "Starting monitors for: $LABEL"

# GPU detailed stats
nvidia-smi \
    --query-gpu=timestamp,\
utilization.gpu,utilization.memory,\
memory.used,memory.free \
    --format=csv \
    -l 1 \
    > $OUTPUT_DIR/${LABEL}_${TS}_gpu.log &
GPU_PID=$!

# Per core CPU stats
mpstat -P ALL 1 $DURATION \
    > $OUTPUT_DIR/${LABEL}_${TS}_cpu.log &
CPU_PID=$!

# Softirq specific
sar -I ALL 1 $DURATION \
    > $OUTPUT_DIR/${LABEL}_${TS}_irq.log &
IRQ_PID=$!

echo "Monitors running — start iperf on Server B now"
echo "Duration: ${DURATION}s"

sleep $DURATION
kill $GPU_PID $CPU_PID $IRQ_PID 2>/dev/null
wait 2>/dev/null

echo "Done — files saved to $OUTPUT_DIR/"
ls -lh $OUTPUT_DIR/${LABEL}_${TS}_*.log


