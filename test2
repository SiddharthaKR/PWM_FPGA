#!/bin/bash
# ethtool_throughput.sh
# Measures real RX throughput from NIC counters

IFACE="enp70s0"
DURATION=30
LABEL=${1:-"test"}
OUTPUT="./results/ethtool_${LABEL}_\
$(date +%H%M%S).txt"

mkdir -p ./results

# Auto detect counter name
get_rx_bytes() {
    for ctr in rx_bytes_phy rx_bytes \
               rx0_bytes port_rx_bytes; do
        val=$(ethtool -S $IFACE 2>/dev/null | \
            grep "^ *${ctr}:" | \
            awk '{print $2}')
        [ -n "$val" ] && echo $val && return
    done
    cat /sys/class/net/$IFACE/statistics/rx_bytes
}

get_rx_pkts() {
    for ctr in rx_packets_phy rx_packets \
               rx0_packets port_rx_packets; do
        val=$(ethtool -S $IFACE 2>/dev/null | \
            grep "^ *${ctr}:" | \
            awk '{print $2}')
        [ -n "$val" ] && echo $val && return
    done
    cat /sys/class/net/$IFACE/statistics/rx_packets
}

echo "=======================================" | tee $OUTPUT
echo "  RX Throughput — $LABEL"               | tee -a $OUTPUT
echo "  Interface : $IFACE"                   | tee -a $OUTPUT
echo "  $(date)"                              | tee -a $OUTPUT
echo "=======================================" | tee -a $OUTPUT
printf "%-8s %-14s %-12s\n" \
    "Time" "Throughput" "Packets/s" | tee -a $OUTPUT
echo "───────────────────────────────────────" | tee -a $OUTPUT

PREV_B=$(get_rx_bytes)
PREV_P=$(get_rx_pkts)
TOTAL_B=0
COUNT=0
MAX_GBPS=0

for i in $(seq 1 $DURATION); do
    sleep 1

    CURR_B=$(get_rx_bytes)
    CURR_P=$(get_rx_pkts)

    DB=$(( CURR_B - PREV_B ))
    DP=$(( CURR_P - PREV_P ))

    GBPS=$(echo "scale=3; $DB*8/1000000000" | bc)
    MPPS=$(echo "scale=3; $DP/1000000"      | bc)

    TOTAL_B=$(( TOTAL_B + DB ))
    COUNT=$(( COUNT + 1 ))

    IS_MAX=$(echo "$GBPS > $MAX_GBPS" | bc)
    [ "$IS_MAX" = "1" ] && MAX_GBPS=$GBPS

    printf "%-8s %-14s %-12s\n" \
        "${i}s" \
        "${GBPS} Gbps" \
        "${MPPS} Mpps" | tee -a $OUTPUT

    PREV_B=$CURR_B
    PREV_P=$CURR_P
done

AVG=$(echo "scale=3; \
    $TOTAL_B*8/$COUNT/1000000000" | bc)

echo "───────────────────────────────────────" | tee -a $OUTPUT
echo "  Average : ${AVG} Gbps"   | tee -a $OUTPUT
echo "  Peak    : ${MAX_GBPS} Gbps" | tee -a $OUTPUT
echo "=======================================" | tee -a $OUTPUT
echo "Saved: $OUTPUT"


