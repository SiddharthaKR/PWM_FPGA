BATCH_SIZES = [1, 8, 32, 64, 128, 256]

def benchmark_batched_cpu_memcpy(pkt_size,
                                  batch_size,
                                  iterations):
    """
    Batched CPU memcpy
    Simulates receiving batch_size packets
    at once and copying to GPU
    """
    # Allocate batch buffer
    total_size = pkt_size * batch_size
    src_arr = np.random.randint(
        0, 255, total_size, dtype=np.uint8)
    dst_arr = cp.zeros(total_size, dtype=cp.uint8)

    # Warmup
    for _ in range(WARMUP):
        dst_arr = cp.asarray(src_arr)
    cp.cuda.Stream.null.synchronize()

    # Measure
    start = time.perf_counter()
    for _ in range(iterations):
        dst_arr = cp.asarray(src_arr)
    cp.cuda.Stream.null.synchronize()
    elapsed = time.perf_counter() - start

    # Throughput = all bytes transferred
    gbps = (total_size * iterations * 8) \
           / elapsed / 1e9
    lat_us = (elapsed / iterations) * 1e6
    pps = (batch_size * iterations) / elapsed

    return gbps, lat_us, pps


def run_batch_benchmark():
    PKT_SIZE = 1024
    ITERS    = 10000

    print("\n" + "=" * 65)
    print("  Batched Transfer Benchmark")
    print(f"  Packet size: {PKT_SIZE}B")
    print("=" * 65)
    print(f"\n{'Batch':>8} {'Total Size':>12} "
          f"{'Throughput':>12} {'Latency':>10} "
          f"{'Pkt/sec':>12}")
    print("-" * 65)

    for batch in BATCH_SIZES:
        gbps, lat, pps = benchmark_batched_cpu_memcpy(
            PKT_SIZE, batch, ITERS)

        total = PKT_SIZE * batch
        total_str = (f"{total}B"
                     if total < 1024
                     else f"{total//1024}KB")

        print(f"{batch:>8} {total_str:>12} "
              f"{gbps:>10.2f}Gbps "
              f"{lat:>8.1f}us "
              f"{pps:>10.0f} pps")

    print("-" * 65)
    print(f"\n  GPUDirect comparison at batch=64:")
    print(f"  CPU batched  : see above")
    print(f"  GPUDirect    : 65 Gbps  ~5M pps")
    print("=" * 65)

run_batch_benchmark()  # batched benchmark


# three_way_benchmark.py
# Measures CPU memcpy vs Pinned Memory vs Async DMA
# Run on Server A alone — no traffic needed

import numpy as np
import time
import os
import sys

try:
    import cupy as cp
    import cupy.cuda as cuda
    print("CuPy available ✅")
except ImportError:
    print("CuPy not available ❌")
    print("Run: source ~/gpu_benchmark_env/bin/activate")
    sys.exit(1)

# ─── Parameters ──────────────────────────────────
PKT_SIZES  = [64, 512, 1024, 2048, 4096]
ITERATIONS = 10000
WARMUP     = 100
OUTPUT     = "./results/phase1_cpu_benchmark.txt"

os.makedirs("./results", exist_ok=True)

# ─── Benchmark Functions ─────────────────────────

def benchmark_cpu_memcpy(size, iterations):
    """
    Method 1 — Traditional CPU memcpy
    Simulates: NIC → CPU RAM → cudaMemcpy → GPU
    """
    src_arr = np.random.randint(
        0, 255, size, dtype=np.uint8)
    dst_arr = cp.zeros(size, dtype=cp.uint8)

    # Warmup
    for _ in range(WARMUP):
        dst_arr = cp.asarray(src_arr)
    cp.cuda.Stream.null.synchronize()

    # Measure
    start = time.perf_counter()
    for _ in range(iterations):
        dst_arr = cp.asarray(src_arr)
    cp.cuda.Stream.null.synchronize()
    elapsed = time.perf_counter() - start

    gbps   = (size * iterations * 8) / elapsed / 1e9
    lat_us = (elapsed / iterations) * 1e6
    return gbps, lat_us


def benchmark_pinned_memory(size, iterations):
    """
    Method 2 — Pinned (Page-locked) Memory
    Simulates: NIC → pinned CPU RAM → GPU
    Faster than memcpy because no page fault
    """
    src_pinned = cuda.alloc_pinned_memory(size)
    src_arr    = np.frombuffer(
        src_pinned, dtype=np.uint8, count=size)
    src_arr[:] = np.random.randint(
        0, 255, size, dtype=np.uint8)
    dst_arr = cp.zeros(size, dtype=cp.uint8)

    # Warmup
    for _ in range(WARMUP):
        dst_arr = cp.asarray(src_arr)
    cp.cuda.Stream.null.synchronize()

    # Measure
    start = time.perf_counter()
    for _ in range(iterations):
        dst_arr = cp.asarray(src_arr)
    cp.cuda.Stream.null.synchronize()
    elapsed = time.perf_counter() - start

    gbps   = (size * iterations * 8) / elapsed / 1e9
    lat_us = (elapsed / iterations) * 1e6
    return gbps, lat_us


def benchmark_async_dma(size, iterations):
    """
    Method 3 — Async DMA (cudaMemcpyAsync)
    Simulates: NIC → CPU RAM → DMA engine → GPU
    CPU not blocked but copy still happens
    """
    src_arr = np.random.randint(
        0, 255, size, dtype=np.uint8)
    dst_arr = cp.zeros(size, dtype=cp.uint8)
    stream  = cp.cuda.Stream(non_blocking=True)

    # Warmup
    for _ in range(WARMUP):
        with stream:
            dst_arr = cp.asarray(src_arr)
    stream.synchronize()

    # Measure
    start = time.perf_counter()
    for _ in range(iterations):
        with stream:
            dst_arr = cp.asarray(src_arr)
    stream.synchronize()
    elapsed = time.perf_counter() - start

    gbps   = (size * iterations * 8) / elapsed / 1e9
    lat_us = (elapsed / iterations) * 1e6
    return gbps, lat_us


# ─── Main ────────────────────────────────────────

def main():
    results = {}

    header = (
        "\n" + "=" * 70 + "\n"
        "  Packet Transfer to GPU — Method Comparison\n"
        "  Hardware: NVIDIA T400 (sm_75)\n"
        "  Iterations per test: {}\n"
        "=" * 70
    ).format(ITERATIONS)

    print(header)

    col_header = (
        f"\n{'Size':>8} "
        f"{'CPU memcpy':>16} "
        f"{'Pinned Mem':>16} "
        f"{'Async DMA':>16}\n"
        f"{'':>8} "
        f"{'Gbps / lat':>16} "
        f"{'Gbps / lat':>16} "
        f"{'Gbps / lat':>16}"
    )
    divider = "-" * 70

    print(col_header)
    print(divider)

    for size in PKT_SIZES:
        size_str = (
            f"{size}B"      if size < 1024      else
            f"{size//1024}KB" if size < 1048576  else
            f"{size//1048576}MB"
        )

        print(f"  Testing {size_str}...", end='\r')

        cpu_gbps, cpu_lat = benchmark_cpu_memcpy(
            size, ITERATIONS)
        pin_gbps, pin_lat = benchmark_pinned_memory(
            size, ITERATIONS)
        dma_gbps, dma_lat = benchmark_async_dma(
            size, ITERATIONS)

        results[size] = {
            'cpu': (cpu_gbps, cpu_lat),
            'pin': (pin_gbps, pin_lat),
            'dma': (dma_gbps, dma_lat)
        }

        row = (
            f"{size_str:>8} "
            f"{cpu_gbps:>8.2f}Gbps "
            f"{cpu_lat:>4.1f}us "
            f"{pin_gbps:>8.2f}Gbps "
            f"{pin_lat:>4.1f}us "
            f"{dma_gbps:>8.2f}Gbps "
            f"{dma_lat:>4.1f}us"
        )
        print(row)

    # GPUDirect note
    print("\n" + "=" * 70)
    print("  Method 4 — GPUDirect RDMA (measured live via DOCA app)")
    print("  NIC → DPU → GPU directly — zero CPU copy")
    print("  CPU cost: ~2-5% softirq vs ~35% for CPU memcpy")
    print("  See Phase 2 and Phase 3 results for comparison")
    print("=" * 70)

    # Summary at 1024B
    print("\n  IMPROVEMENT SUMMARY (1024B packet size):")
    print("  " + "-" * 50)
    r      = results[1024]
    cpu_g  = r['cpu'][0]
    cpu_l  = r['cpu'][1]
    pin_g  = r['pin'][0]
    pin_l  = r['pin'][1]
    dma_g  = r['dma'][0]
    dma_l  = r['dma'][1]

    pin_improvement = ((pin_g - cpu_g) / cpu_g) * 100
    dma_improvement = ((dma_g - cpu_g) / cpu_g) * 100

    print(f"  CPU memcpy    : {cpu_g:>6.2f} Gbps  "
          f"{cpu_l:>6.1f} us  baseline")
    print(f"  Pinned memory : {pin_g:>6.2f} Gbps  "
          f"{pin_l:>6.1f} us  "
          f"{pin_improvement:>+.1f}% vs CPU")
    print(f"  Async DMA     : {dma_g:>6.2f} Gbps  "
          f"{dma_l:>6.1f} us  "
          f"{dma_improvement:>+.1f}% vs CPU")
    print(f"  GPUDirect     : see live demo      "
          f"~94% less CPU overhead")
    print("=" * 70 + "\n")

    # Save results
    with open(OUTPUT, 'w') as f:
        f.write(header + "\n")
        f.write(col_header + "\n")
        f.write(divider + "\n")
        for size in PKT_SIZES:
            size_str = (
                f"{size}B"        if size < 1024     else
                f"{size//1024}KB" if size < 1048576  else
                f"{size//1048576}MB"
            )
            r = results[size]
            f.write(
                f"{size_str:>8} "
                f"{r['cpu'][0]:>8.2f}Gbps "
                f"{r['cpu'][1]:>4.1f}us "
                f"{r['pin'][0]:>8.2f}Gbps "
                f"{r['pin'][1]:>4.1f}us "
                f"{r['dma'][0]:>8.2f}Gbps "
                f"{r['dma'][1]:>4.1f}us\n"
            )
        f.write(
            f"\nSUMMARY 1024B:\n"
            f"CPU memcpy    : {cpu_g:.2f} Gbps\n"
            f"Pinned memory : {pin_g:.2f} Gbps "
            f"({pin_improvement:+.1f}%)\n"
            f"Async DMA     : {dma_g:.2f} Gbps "
            f"({dma_improvement:+.1f}%)\n"
            f"GPUDirect     : measured live\n"
        )

    print(f"Results saved to: {OUTPUT}")

if __name__ == "__main__":
    main()


