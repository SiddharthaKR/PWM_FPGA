# Save as gpudirect_benchmark.py
cat > gpudirect_benchmark.py << 'EOF'
import subprocess
import time
import re

def get_doca_counter():
    """Read DOCA app packet counter"""
    # Read from app output file
    try:
        with open('/tmp/doca_output.txt', 'r') as f:
            lines = f.readlines()
            for line in reversed(lines):
                if 'TOTAL' in line:
                    match = re.search(r'TOTAL:\s*(\d+)', line)
                    if match:
                        return int(match.group(1))
    except:
        pass
    return 0

def measure_gpudirect_throughput(pkt_size=1024, duration=10):
    print("=" * 50)
    print("  GPUDirect RDMA Path Benchmark")
    print(f"  Packet size: {pkt_size}B")
    print(f"  Duration: {duration}s")
    print("=" * 50)

    print("\nMake sure:")
    print("1. DOCA app is running on Server A")
    print("2. iperf3 is sending from Server B")
    print("")
    input("Press ENTER when iperf3 is running...")

    # Sample counters
    samples = []
    for i in range(duration):
        count = get_doca_counter()
        samples.append((time.time(), count))
        print(f"  {i+1}s: {count} total packets", end='\r')
        time.sleep(1)

    print("")

    # Calculate throughput from counter deltas
    rates = []
    for i in range(1, len(samples)):
        dt = samples[i][0] - samples[i-1][0]
        dpkts = samples[i][1] - samples[i-1][1]
        pps = dpkts / dt
        gbps = pps * pkt_size * 8 / 1e9
        rates.append(gbps)

    if rates:
        avg_gbps = sum(rates) / len(rates)
        max_gbps = max(rates)
        print(f"\n  Average throughput : {avg_gbps:.3f} Gbps")
        print(f"  Peak throughput    : {max_gbps:.3f} Gbps")
        print(f"  Packets/sec        : "
              f"{avg_gbps*1e9/pkt_size/8:.0f} pps")

    print("=" * 50)
    return avg_gbps if rates else 0

if __name__ == "__main__":
    result = measure_gpudirect_throughput(
        pkt_size=1024,
        duration=10
    )
EOF

