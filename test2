cat > cpu_copy_benchmark.py << 'EOF'
import numpy as np
import time
import subprocess

try:
    import cupy as cp
    HAS_CUPY = True
except:
    HAS_CUPY = False

try:
    import pycuda.driver as cuda
    import pycuda.autoinit
    HAS_PYCUDA = True
except:
    HAS_PYCUDA = False

def measure_cpu_to_gpu_throughput():
    print("=" * 50)
    print("  Traditional CPU → GPU Copy Benchmark")
    print("=" * 50)

    # Packet sizes to test
    sizes_bytes = [
        64,
        512,
        1024,
        2048,
        4096,
        65536,
        1048576,   # 1MB
        10485760,  # 10MB
    ]

    iterations = 1000

    print(f"\n{'Size':>10} {'Throughput':>15} {'Latency':>12}")
    print("-" * 40)

    if HAS_CUPY:
        for size in sizes_bytes:
            # Allocate CPU buffer (simulates NIC received data)
            cpu_buf = np.random.bytes(size)
            cpu_arr = np.frombuffer(cpu_buf, dtype=np.uint8)

            # Allocate GPU buffer
            gpu_arr = cp.zeros(size, dtype=cp.uint8)

            # Warmup
            for _ in range(10):
                gpu_arr = cp.asarray(cpu_arr)
            cp.cuda.Stream.null.synchronize()

            # Measure
            start = time.perf_counter()
            for _ in range(iterations):
                gpu_arr = cp.asarray(cpu_arr)
            cp.cuda.Stream.null.synchronize()
            end = time.perf_counter()

            elapsed = end - start
            total_bytes = size * iterations
            throughput_gbps = (total_bytes * 8) / elapsed / 1e9
            latency_us = (elapsed / iterations) * 1e6

            size_str = f"{size}B" if size < 1024 else \
                       f"{size//1024}KB" if size < 1048576 else \
                       f"{size//1048576}MB"

            print(f"{size_str:>10} "
                  f"{throughput_gbps:>12.3f} Gbps "
                  f"{latency_us:>10.2f} us")

    else:
        print("CuPy not installed")
        print("Install: pip install cupy-cuda12x")

    print("=" * 50)

if __name__ == "__main__":
    measure_cpu_to_gpu_throughput()
EOF

