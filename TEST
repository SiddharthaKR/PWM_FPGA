#include <iostream>
#include <cstring>
#include <sys/socket.h>
#include <netinet/in.h>
#include <unistd.h>
#include "xrt/xrt_bo.h"
#include "xrt/xrt_device.h"
#include "xrt.h"

int main() {
    // 1. Connect to U50 — just verify device is reachable
    try {
        xrt::device u50("0000:b1:00.1");
        std::cout << "Connected to Alveo U50\n";
        std::cout << "U50 BDF: " << u50.get_info<xrt::info::device::bdf>() << "\n";
    } catch (const std::exception& e) {
        std::cerr << "U50 connect failed: " << e.what() << "\n";
        return 1;
    }

    // 2. Plain malloc buffer — no XRT allocation needed yet
    const size_t BUF_SIZE = 4096;
    char* host_ptr = new char[BUF_SIZE];
    memset(host_ptr, 0, BUF_SIZE);

    // 3. UDP listener
    int sockfd = socket(AF_INET, SOCK_DGRAM, 0);
    if (sockfd < 0) {
        std::cerr << "Socket failed\n";
        return 1;
    }

    struct sockaddr_in servaddr{};
    servaddr.sin_family      = AF_INET;
    servaddr.sin_port        = htons(8080);
    servaddr.sin_addr.s_addr = INADDR_ANY;

    if (bind(sockfd, (const struct sockaddr*)&servaddr,
             sizeof(servaddr)) < 0) {
        std::cerr << "Bind failed\n";
        return 1;
    }

    std::cout << "Waiting for DPU data on UDP port 8080...\n";

    // 4. Receive from DPU
    struct sockaddr_in sender{};
    socklen_t sender_len = sizeof(sender);
    ssize_t bytes = recvfrom(sockfd, host_ptr, BUF_SIZE,
                             0,
                             (struct sockaddr*)&sender,
                             &sender_len);
    if (bytes < 0) {
        std::cerr << "recvfrom failed\n";
        return 1;
    }

    std::cout << "Received " << bytes << " bytes from DPU\n";
    std::cout << "Data: " << host_ptr << "\n";

    // 5. For now print confirmation — XRT DMA comes after xclbin loaded
    std::cout << "Next step: load xclbin and DMA this buffer to U50 HBM\n";

    close(sockfd);
    delete[] host_ptr;
    return 0;
}


