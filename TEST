#include <iostream>
#include <cstring>
#include <sys/socket.h>
#include <netinet/in.h>

// Modern XRT Headers
#include "experimental/xrt_bo.h"
#include "experimental/xrt_device.h"

int main() {
    // 1. Connect to Alveo U50
    xrt::device u50(0);
    std::cout << "Connected to Alveo U50 (NUMA 0/1).\n";

    // 2. Allocate Normal Buffer (Host RAM pinned by XRT)
    xrt::bo shared_buf(u50, 4096, xrt::bo::flags::normal, 0);
    auto host_ptr = shared_buf.map<char*>(); // Map as char* for easy text reading
    
    // 3. Set up a quick UDP listener on the Host
    int sockfd = socket(AF_INET, SOCK_DGRAM, 0);
    struct sockaddr_in servaddr;
    servaddr.sin_family = AF_INET;
    servaddr.sin_port = htons(8080);
    servaddr.sin_addr.s_addr = INADDR_ANY;
    bind(sockfd, (const struct sockaddr *)&servaddr, sizeof(servaddr));

    std::cout << "Waiting for DPU data on UDP Port 8080...\n";

    // 4. Catch the data from the DPU and put it directly into the mapped XRT buffer
    recvfrom(sockfd, host_ptr, 4096, MSG_WAITALL, NULL, NULL);
    std::cout << "Host CPU intercepted DPU data: " << host_ptr << "\n";

    // 5. Fire it down to the FPGA!
    std::cout << "Syncing from Host RAM -> Alveo U50...\n";
    shared_buf.sync(xrt::bo::direction::host_to_device);
    
    std::cout << "SUCCESS: Data is in the FPGA.\n";

    return 0;
}
